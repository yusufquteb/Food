<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<androidx.coordinatorlayout.widget.CoordinatorLayout
		android:id="@+id/coordinator_layout17"
		android:layout_width="match_parent"
		android:layout_height="match_parent">
		<androidx.core.widget.NestedScrollView
			android:id="@+id/vscroll2"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:fillViewport="true">
			<LinearLayout
				android:id="@+id/bg"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="#F8F9FA"
				android:orientation="vertical"
				android:paddingHorizontal="16dp">
				<LinearLayout
					android:id="@+id/topBarLayout"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:paddingVertical="12dp">
					<ImageView
						android:id="@+id/menuIcon"
						android:layout_width="48dp"
						android:layout_height="48dp"
						android:padding="8dp"
						android:src="@drawable/menu"
						android:scaleType="fitCenter"
						android:background="?attr/selectableItemBackgroundBorderless"
						android:contentDescription="Menu" />
					<View
						android:id="@+id/view18"
						android:layout_width="0dp"
						android:layout_height="0dp"
						android:layout_weight="1" />
					<com.google.android.material.imageview.ShapeableImageView
						android:id="@+id/profileImage"
						android:layout_width="48dp"
						android:layout_height="48dp"
						android:padding="2dp"
						android:src="@drawable/man"
						app:shapeAppearanceOverlay="@style/circleImageView" />
				</LinearLayout>
				<TextView
					android:id="@+id/mainHeaderText"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="16dp"
					android:layout_marginBottom="24dp"
					android:text="ماذا تريد أن تطبخ؟"
					android:textSize="32sp"
					android:textStyle="bold"
					android:textColor="#212529"
					android:gravity="end" />
				<com.google.android.material.card.MaterialCardView
					android:id="@+id/searchCardView"
					android:layout_width="match_parent"
					android:layout_height="56dp"
					android:layout_marginBottom="32dp"
					app:cardCornerRadius="28dp"
					app:cardElevation="3dp">
					<LinearLayout
						android:id="@+id/linear19"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:layout_marginLeft="5dp"
						android:layout_marginRight="5dp"
						android:gravity="center_vertical"
						android:orientation="horizontal"
						android:paddingHorizontal="16dp">
						<ImageView
							android:id="@+id/searchIcon"
							android:layout_width="24dp"
							android:layout_height="24dp"
							android:src="@drawable/search"
							android:scaleType="fitCenter"
							android:layout_marginEnd="12dp"
							android:contentDescription="Search" />
						<EditText
							android:id="@+id/searchEditText"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:textSize="16sp"
							android:textColor="#212529"
							android:hint="ابحث هنا"
							android:textColorHint="#757575"
							android:background="@null"
							android:importantForAutofill="no" />
					</LinearLayout>
				</com.google.android.material.card.MaterialCardView>
				<LinearLayout
					android:id="@+id/categoriesSectionHeader"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginBottom="16dp"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<TextView
						android:id="@+id/categoriesViewMore"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="المزيد"
						android:textSize="14sp"
						android:textColor="#2962FF"
						android:background="?attr/selectableItemBackground" />
					<TextView
						android:id="@+id/categoriesTitle"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:text="الأقسام"
						android:textSize="24sp"
						android:textStyle="bold"
						android:textColor="#212529"
						android:layout_weight="1" />
				</LinearLayout>
				<HorizontalScrollView
					android:id="@+id/categoriesHorizontalScroll"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginBottom="32dp"
					android:scrollbars="none">
					<LinearLayout
						android:id="@+id/linear20"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:orientation="horizontal">
						<com.google.android.material.card.MaterialCardView
							android:id="@+id/riceCardView"
							android:layout_width="120dp"
							android:layout_height="180dp"
							android:layout_marginEnd="16dp"
							app:cardCornerRadius="16dp"
							app:cardElevation="4dp">
							<FrameLayout
								android:id="@+id/frame_layout21"
								android:layout_width="match_parent"
								android:layout_height="match_parent">
								<ImageView
									android:id="@+id/imageview9"
									android:layout_width="match_parent"
									android:layout_height="match_parent"
									android:src="@drawable/rice"
									android:scaleType="centerCrop" />
								<View
									android:id="@+id/view22"
									android:layout_width="match_parent"
									android:layout_height="match_parent"
									android:background="@drawable/gradient_overlay" />
								<TextView
									android:id="@+id/textview9"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="12dp"
									android:text="قسم الأرز"
									android:textSize="18sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF"
									android:layout_gravity="center_horizontal|bottom" />
							</FrameLayout>
						</com.google.android.material.card.MaterialCardView>
						<com.google.android.material.card.MaterialCardView
							android:id="@+id/meatCardView"
							android:layout_width="120dp"
							android:layout_height="180dp"
							android:layout_marginEnd="16dp"
							app:cardCornerRadius="16dp"
							app:cardElevation="4dp">
							<FrameLayout
								android:id="@+id/frame_layout23"
								android:layout_width="match_parent"
								android:layout_height="match_parent">
								<ImageView
									android:id="@+id/imageview10"
									android:layout_width="match_parent"
									android:layout_height="match_parent"
									android:src="@drawable/meat"
									android:scaleType="centerCrop" />
								<View
									android:id="@+id/view24"
									android:layout_width="match_parent"
									android:layout_height="match_parent"
									android:background="@drawable/gradient_overlay" />
								<TextView
									android:id="@+id/textview10"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="12dp"
									android:text="قسم اللحوم"
									android:textSize="18sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF"
									android:layout_gravity="center_horizontal|bottom" />
							</FrameLayout>
						</com.google.android.material.card.MaterialCardView>
						<com.google.android.material.card.MaterialCardView
							android:id="@+id/dessertsCardView"
							android:layout_width="120dp"
							android:layout_height="180dp"
							android:layout_marginEnd="16dp"
							app:cardCornerRadius="16dp"
							app:cardElevation="4dp">
							<FrameLayout
								android:id="@+id/frame_layout25"
								android:layout_width="match_parent"
								android:layout_height="match_parent">
								<ImageView
									android:id="@+id/imageview11"
									android:layout_width="match_parent"
									android:layout_height="match_parent"
									android:src="@drawable/desert"
									android:scaleType="centerCrop" />
								<View
									android:id="@+id/view26"
									android:layout_width="match_parent"
									android:layout_height="match_parent"
									android:background="@drawable/gradient_overlay" />
								<TextView
									android:id="@+id/textview11"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="12dp"
									android:text="قسم الحلويات"
									android:textSize="18sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF"
									android:layout_gravity="center_horizontal|bottom" />
							</FrameLayout>
						</com.google.android.material.card.MaterialCardView>
						<com.google.android.material.card.MaterialCardView
							android:id="@+id/pastryCardView"
							android:layout_width="120dp"
							android:layout_height="180dp"
							app:cardCornerRadius="16dp"
							app:cardElevation="4dp">
							<FrameLayout
								android:id="@+id/frame_layout27"
								android:layout_width="match_parent"
								android:layout_height="match_parent">
								<ImageView
									android:id="@+id/imageview12"
									android:layout_width="match_parent"
									android:layout_height="match_parent"
									android:src="@drawable/baking"
									android:scaleType="centerCrop" />
								<View
									android:id="@+id/view28"
									android:layout_width="match_parent"
									android:layout_height="match_parent"
									android:background="@drawable/gradient_overlay" />
								<TextView
									android:id="@+id/textview12"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="12dp"
									android:text="قسم الفطائر"
									android:textSize="18sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF"
									android:layout_gravity="center_horizontal|bottom" />
							</FrameLayout>
						</com.google.android.material.card.MaterialCardView>
					</LinearLayout>
				</HorizontalScrollView>
				<LinearLayout
					android:id="@+id/recentSectionHeader"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginBottom="16dp"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<TextView
						android:id="@+id/recentViewMore"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="المزيد"
						android:textSize="14sp"
						android:textColor="#2962FF"
						android:background="?attr/selectableItemBackground" />
					<TextView
						android:id="@+id/recentTitle"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:text="ما تم مشاهدته مؤخرا"
						android:textSize="24sp"
						android:textStyle="bold"
						android:textColor="#212529"
						android:layout_weight="1" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/recentItemsContainer"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/recentItem1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						app:cardCornerRadius="16dp"
						app:cardElevation="3dp">
						<LinearLayout
							android:id="@+id/linear29"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="12dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<com.google.android.material.card.MaterialCardView
								android:id="@+id/cardview3"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								app:cardCornerRadius="12dp"
								app:cardElevation="0dp">
								<ImageView
									android:id="@+id/imageview13"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/rice"
									android:scaleType="centerCrop" />
							</com.google.android.material.card.MaterialCardView>
							<LinearLayout
								android:id="@+id/linear30"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:orientation="vertical"
								android:layout_weight="1"
								android:layout_marginStart="16dp">
								<TextView
									android:id="@+id/textview13"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="خلطبيطة بالصلصة"
									android:textSize="16sp"
									android:textStyle="bold"
									android:textColor="#212529" />
								<TextView
									android:id="@+id/textview14"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_marginTop="4dp"
									android:text="قسم المجانين"
									android:textSize="14sp"
									android:textColor="#757575" />
							</LinearLayout>
							<ImageView
								android:id="@+id/imageview14"
								android:layout_width="36dp"
								android:layout_height="36dp"
								android:padding="6dp"
								android:src="@drawable/ic_more_vert_white"
								android:scaleType="center"
								android:background="?attr/selectableItemBackgroundBorderless"
								android:contentDescription="Moreoptions" />
						</LinearLayout>
					</com.google.android.material.card.MaterialCardView>
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/recentItem2"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="16dp"
						app:cardCornerRadius="16dp"
						app:cardElevation="3dp">
						<LinearLayout
							android:id="@+id/linear31"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="12dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<com.google.android.material.card.MaterialCardView
								android:id="@+id/cardview4"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								app:cardCornerRadius="12dp"
								app:cardElevation="0dp">
								<ImageView
									android:id="@+id/imageview15"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/meat"
									android:scaleType="centerCrop" />
							</com.google.android.material.card.MaterialCardView>
							<LinearLayout
								android:id="@+id/linear32"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:orientation="vertical"
								android:layout_weight="1"
								android:layout_marginStart="16dp">
								<TextView
									android:id="@+id/textview15"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="مسقعة بالمكسرات"
									android:textSize="16sp"
									android:textStyle="bold"
									android:textColor="#212529" />
								<TextView
									android:id="@+id/textview16"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_marginTop="4dp"
									android:text="قسم العكاكين"
									android:textSize="14sp"
									android:textColor="#757575" />
							</LinearLayout>
							<ImageView
								android:id="@+id/imageview16"
								android:layout_width="36dp"
								android:layout_height="36dp"
								android:padding="6dp"
								android:src="@drawable/ic_more_vert_white"
								android:scaleType="center"
								android:background="?attr/selectableItemBackgroundBorderless"
								android:contentDescription="Moreoptions" />
						</LinearLayout>
					</com.google.android.material.card.MaterialCardView>
				</LinearLayout>
			</LinearLayout>
		</androidx.core.widget.NestedScrollView>
		<com.google.android.material.bottomnavigation.BottomNavigationView
			android:id="@+id/bottomNavigation"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:background="#FFFFFF"
			android:layout_gravity="bottom"
			app:menu="@menu/bottom_navigation_menu"
			app:labelVisibilityMode="labeled"
			app:elevation="16dp" />
	</androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>
