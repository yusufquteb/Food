<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<androidx.coordinatorlayout.widget.CoordinatorLayout
		android:id="@+id/coordinator_layout28"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@color/md_theme_light_background">
		<com.google.android.material.appbar.AppBarLayout
			android:id="@+id/appBarLayout"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:background="@color/md_theme_light_surfaceContainerHigh"
			app:elevation="0dp"
			app:liftOnScroll="true">
			<androidx.appcompat.widget.Toolbar
				android:id="@+id/toolbar"
				android:layout_width="match_parent"
				android:background="@color/md_theme_light_surfaceContainerHigh"
				android:layout_height="?attr/actionBarSize">
				<LinearLayout
					android:id="@+id/linear11"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/logoImageView"
						android:layout_width="32dp"
						android:layout_height="32dp"
						android:src="@drawable/exitic"
						android:scaleType="fitCenter"
						android:contentDescription="@string/app_logo" />
					<TextView
						android:id="@+id/titleTextView"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="center_vertical"
						android:text="Food Review"
						android:textSize="18sp"
						android:textStyle="bold"
						android:textColor="@color/md_theme_light_onSurface"
						android:layout_weight="1" />
				</LinearLayout>
			</androidx.appcompat.widget.Toolbar>
		</com.google.android.material.appbar.AppBarLayout>
		<androidx.core.widget.NestedScrollView
			android:id="@+id/nestedScrollView"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:fillViewport="true"
			app:layout_behavior="@string/appbar_scrolling_view_behavior">
			<LinearLayout
				android:id="@+id/mainContainer"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<FrameLayout
					android:id="@+id/frame_layout12"
					android:layout_width="match_parent"
					android:layout_height="wrap_content">
					<ImageView
						android:id="@+id/foodImage"
						android:layout_width="match_parent"
						android:layout_height="260dp"
						android:src="@drawable/image_29"
						android:scaleType="centerCrop"
						android:contentDescription="@string/food_image" />
					<View
						android:id="@+id/view13"
						android:layout_width="match_parent"
						android:layout_height="100dp"
						android:background="@drawable/gradient_overlay"
						android:layout_gravity="bottom" />
				</FrameLayout>
				<androidx.cardview.widget.CardView
					android:id="@+id/detailsCardView"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginBottom="16dp"
					android:layout_marginTop="-24dp"
					android:layout_marginStart="16dp"
					android:layout_marginEnd="16dp"
					app:cardCornerRadius="24dp"
					app:cardElevation="6dp"
					app:cardBackgroundColor="@color/md_theme_light_surface">
					<LinearLayout
						android:id="@+id/cardContent"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="20dp"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/titleSection"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginBottom="16dp"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear14"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:orientation="vertical"
								android:layout_weight="1">
								<TextView
									android:id="@+id/foodNameTextView"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="Asian Salad"
									android:textSize="22sp"
									android:textStyle="bold"
									android:textColor="@color/md_theme_light_onSurface" />
								<TextView
									android:id="@+id/foodSizeTextView"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_marginTop="4dp"
									android:text="Medium"
									android:textSize="14sp"
									android:textColor="@color/md_theme_light_onSurfaceVariant" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear15"
								android:layout_width="wrap_content"
								android:layout_height="match_parent"
								android:gravity="center_vertical"
								android:orientation="horizontal">
								<ImageView
									android:id="@+id/likeButton"
									android:layout_width="44dp"
									android:layout_height="44dp"
									android:padding="6dp"
									android:src="@drawable/like"
									android:scaleType="center"
									android:foreground="?attr/selectableItemBackgroundBorderless"
									android:contentDescription="@string/like_button" />
							</LinearLayout>
						</LinearLayout>
						<View
							android:id="@+id/divider"
							android:layout_width="match_parent"
							android:layout_height="1dp"
							android:layout_marginBottom="16dp"
							android:background="@color/md_theme_light_outlineVariant" />
						<TextView
							android:id="@+id/ingredientsLabelTextView"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginBottom="8dp"
							android:text="المكونات"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/md_theme_light_primary" />
						<TextView
							android:id="@+id/ingredientsContentTextView"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginBottom="16dp"
							android:text="1 كوب خس مقطع\n1/2 كوب جزر مبشور\n1/4 كوب بصل أخضر مقطع\n2 ملعقة كبيرة صلصة الصويا\n1 ملعقة كبيرة زيت سمسم\n1 ملعقة صغيرة عسل\nرشة فلفل أحمر حار"
							android:textSize="14sp"
							android:textColor="@color/md_theme_light_onSurface"
							android:lineSpacingExtra="4dp" />
						<TextView
							android:id="@+id/preparationLabelTextView"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginBottom="8dp"
							android:text="طريقة التحضير"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/md_theme_light_primary" />
						<TextView
							android:id="@+id/preparationContentTextView"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="1. اخلطي الخس والجزر والبصل الأخضر في وعاء كبير.\n2. في وعاء صغير، اخلطي صلصة الصويا وزيت السمسم والعسل والفلفل الأحمر.\n3. أضيفي الصلصة إلى الخضار واخلطي جيداً.\n4. قدمي السلطة فوراً أو احفظيها في الثلاجة لمدة 30 دقيقة حتى تمتزج النكهات."
							android:textSize="14sp"
							android:textColor="@color/md_theme_light_onSurface"
							android:lineSpacingExtra="6dp" />
						<TextView
							android:id="@+id/nutritionLabelTextView"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="16dp"
							android:layout_marginBottom="12dp"
							android:text="القيمة الغذائية"
							android:textSize="16sp"
							android:textStyle="bold"
							android:textColor="@color/md_theme_light_primary" />
						<LinearLayout
							android:id="@+id/linear16"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:background="@color/md_theme_light_surfaceContainerLow"
							android:padding="8dp"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear17"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<TextView
									android:id="@+id/textview10"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="120"
									android:textSize="18sp"
									android:textStyle="bold"
									android:textColor="#FF5722" />
								<TextView
									android:id="@+id/textview11"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="سعرات حرارية"
									android:textSize="11sp"
									android:textColor="@color/md_theme_light_onSurfaceVariant" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear18"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<TextView
									android:id="@+id/textview12"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="3g"
									android:textSize="18sp"
									android:textStyle="bold"
									android:textColor="#4CAF50" />
								<TextView
									android:id="@+id/textview13"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="بروتين"
									android:textSize="11sp"
									android:textColor="@color/md_theme_light_onSurfaceVariant" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear19"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<TextView
									android:id="@+id/textview14"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="6g"
									android:textSize="18sp"
									android:textStyle="bold"
									android:textColor="@color/md_theme_light_primary" />
								<TextView
									android:id="@+id/textview15"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="دهون"
									android:textSize="11sp"
									android:textColor="@color/md_theme_light_onSurfaceVariant" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear20"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<TextView
									android:id="@+id/textview16"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="15g"
									android:textSize="18sp"
									android:textStyle="bold"
									android:textColor="#FFC107" />
								<TextView
									android:id="@+id/textview17"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="كربوهيدرات"
									android:textSize="11sp"
									android:textColor="@color/md_theme_light_onSurfaceVariant" />
							</LinearLayout>
						</LinearLayout>
					</LinearLayout>
				</androidx.cardview.widget.CardView>
				<TextView
					android:id="@+id/textview18"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginBottom="8dp"
					android:text="وصفات مشابهة"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="@color/md_theme_light_onSurface"
					android:layout_marginStart="16dp"
					android:layout_marginEnd="16dp" />
				<androidx.recyclerview.widget.RecyclerView
					android:id="@+id/relatedRecipesRecyclerView"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginBottom="16dp"
					android:layout_marginStart="8dp"
					android:layout_marginEnd="8dp"
					android:clipToPadding="false"
					app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
			</LinearLayout>
		</androidx.core.widget.NestedScrollView>
	</androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>
